# Copy to .env for local runs. GitHub Actions reads these from repo secrets.

# Required for Gemini scoring and tailoring
GEMINI_API_KEY=

# Optional: Adzuna free tier (250 calls/month). Sign up at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: email the daily brief at end of run. Use a Gmail App Password,
# not your normal password. https://support.google.com/accounts/answer/185833
GMAIL_APP_PASSWORD=
GMAIL_FROM_ADDRESS=
GMAIL_TO_ADDRESS=
